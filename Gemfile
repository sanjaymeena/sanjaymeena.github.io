source "https://rubygems.org"

gem "jekyll", "~> 4.3"
gem "webrick", "~> 1.8"  # Required for Ruby 3.0+

# Plugins to match github-pages functionality
group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
  gem "jekyll-paginate"
  gem "jekyll-gist"
  gem "jekyll-include-cache"
  gem "jemoji"
end

gem "wdm", "~> 0.1.0" if Gem.win_platform?